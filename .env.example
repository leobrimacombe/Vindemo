# ──────────────────────────────────────────────────────────────────────────
#  Boutique Shopify (headless — Storefront API)
# ──────────────────────────────────────────────────────────────────────────
#  Copiez ce fichier en `.env.local` (déjà ignoré par git via `*.local`) puis
#  remplissez vos valeurs. SANS ces variables, la boutique fonctionne quand
#  même en MODE DÉMO (produits de fallback définis dans src/data/domaine.js).
#
#  ⚠️  Préfixe VITE_ obligatoire : seules ces variables sont exposées au client.
#  ⚠️  Redémarrez `npm run dev` après toute modification d'un fichier .env.
# ──────────────────────────────────────────────────────────────────────────

# Domaine de la boutique (sans https://), ex. mon-domaine.myshopify.com
VITE_SHOPIFY_DOMAIN=ton-store.myshopify.com

# Storefront API access token (Admin → Settings → Apps → Develop apps →
# ton app → API credentials → "Storefront API access token").
VITE_SHOPIFY_STOREFRONT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Version de l'API Storefront (optionnel — défaut géré dans src/lib/shopify.js).
# Versions trimestrielles au format AAAA-MM.
# VITE_SHOPIFY_API_VERSION=2025-01
